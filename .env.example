# Required for build-time GitHub contributions fetch
GH_TOKEN=github_pat_your_token_here
GH_USERNAME=your-github-username

# Contact form (Cloudflare Pages Function). For local dev set here.
# For production: set in GitHub (environment vars + secret MAILGUN_API_KEY) and/or Cloudflare Pages → Settings → Environment variables (see docs/contact-form-setup.md).
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
CONTACT_TO_EMAIL=you@yourdomain.com
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_API_KEY=mailgun_api_key_here
# MAILGUN_FROM_EMAIL=Contact Form <noreply@mg.yourdomain.com>
# MAILGUN_EU=1   # use EU API endpoint

# Newsletter (Resend)
RESEND_API_KEY=re_your_api_key_here
RESEND_SEGMENT_ID=seg_your_segment_id_here
# Optional. Used for both confirmation and welcome emails.
# NEWSLETTER_FROM=Your Name <newsletter@yourdomain.com>
NEWSLETTER_SECRET=your-random-32-char-secret-here

# Comments (Giscus). Get repo-id and category-id from https://giscus.app after enabling Discussions + Giscus app.
# If unset, the comments section is not shown on writing/project pages.
# GISCUS_REPO=owner/repo
# GISCUS_REPO_ID=R_kgDO...
# GISCUS_CATEGORY_ID=DIC_kwDO...
# GISCUS_CATEGORY=Comments

# Audio delivery. Default/local behavior serves generated files from /audio/ when present.
# Set AUDIO_SOURCE=r2 in production builds to resolve audio URLs from R2 instead.
# AUDIO_SOURCE=local
# R2_AUDIO_PUBLIC_BASE_URL=https://pub-your-bucket-id.r2.dev
# Optional override if the published manifest is not at <public base>/audio-manifest.json
# R2_AUDIO_MANIFEST_URL=https://pub-your-bucket-id.r2.dev/audio-manifest.json

# Audio publishing to R2 (used by pnpm audio:publish)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_AUDIO_BUCKET=your-audio-bucket-name
