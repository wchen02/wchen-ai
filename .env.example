# Required for build-time GitHub contributions fetch
GH_TOKEN=github_pat_your_token_here
GH_USERNAME=your-github-username

# Contact form (Cloudflare Pages Function). For local dev set here.
# For production: set in GitHub (environment vars + secret MAILGUN_API_KEY) and/or Cloudflare Pages → Settings → Environment variables (see docs/contact-form-setup.md).
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
CONTACT_TO_EMAIL=you@yourdomain.com
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_API_KEY=mailgun_api_key_here
# MAILGUN_FROM_EMAIL=Contact Form <noreply@mg.yourdomain.com>
# MAILGUN_EU=1   # use EU API endpoint

# Newsletter (Resend)
RESEND_API_KEY=re_your_api_key_here
RESEND_SEGMENT_ID=seg_your_segment_id_here
# NEWSLETTER_FROM=Your Name <newsletter@yourdomain.com>
NEWSLETTER_SECRET=your-random-32-char-secret-here
