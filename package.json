{
  "name": "wchen-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_ENV=production pnpm run prebuild && next build",
    "audio:generate": "tsx scripts/generate-audio.ts",
    "audio:publish": "(test -f .env && tsx --env-file=.env scripts/upload-audio-to-r2.ts || tsx scripts/upload-audio-to-r2.ts)",
    "newsletter:send-recurring": "(test -f .env && tsx --env-file=.env scripts/send-recurring-newsletter.ts || tsx scripts/send-recurring-newsletter.ts)",
    "prebuild": "tsx scripts/validate-links.ts && tsx scripts/validate-theme-descriptors.ts && (test -f .env && tsx --env-file=.env scripts/fetch-github-data.ts || tsx scripts/fetch-github-data.ts) && tsx scripts/generate-rss.ts && tsx scripts/generate-sitemap.ts && tsx scripts/generate-robots.ts && tsx scripts/generate-search-index.ts && tsx scripts/generate-list-payloads.ts",
    "start": "NODE_ENV=production next start",
    "lint": "pnpm exec eslint .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p functions/tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "postbuild": "tsx scripts/validate-metadata.ts",
    "validate:metadata": "tsx scripts/validate-metadata.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@react-email/components": "^1.0.9",
    "@react-email/render": "^2.0.4",
    "@tailwindcss/typography": "^0.5.19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "framer-motion": "^12.34.3",
    "gray-matter": "^4.0.3",
    "next": "16.1.6",
    "next-mdx-remote": "^6.0.0",
    "node-edge-tts": "^1.2.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "husky": "^9",
    "@axe-core/playwright": "^4.11.1",
    "@cloudflare/workers-types": "^4.20260302.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
